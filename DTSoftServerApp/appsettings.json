{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  // 系统初始化配置
  "InitializeOnStartup": true,
  "urls": "http://*:8000",
  //Scalar API文档配置
  "ScalarEnabled": true,
  "Jwt": {
    "Key": "DTSoftServerApp_Jwt_SecretKey_2026_32chars!@#$%^&*()",
    // 至少16个字符的密钥
    "Issuer": "DTSoftServer",
    "Audience": "DTSoftServerClient"
  },
  // 密码哈希 PBKDF2 迭代次数。数值越高越安全但登录越慢；调整后用户成功登录会自动迁移到新值。
  "PasswordHashing": {
    "Iterations": 120000
  },
  //文件存储根目录
  "RootPath": "Attachment",
  //附件存储路径
  "AttachmentPath": "File",
  //用户数据存储路径
  "UserData": "User",
  //数据库类型（MySql、SqlServer、Oracle、PostgreSql）
  "DBType": "PostgreSql",
  "ConnectionStrings": {
    // "DBConnection": "server=localhost;port=3306;database=DTSoftDB;uid=root;pwd=xxx;charset=utf8mb4;"
    "DBConnection": "Host=localhost;Port=5432;Database=DTSoftDB;Username=postgres;Password=xxx;Pooling=true;Maximum Pool Size=512;Minimum Pool Size=5;SSL Mode=Disable"
    //"DBConnection":"Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=localhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=XE)));User Id=C##DTSOFT;Password=123456;Metadata Pooling=false;Self Tuning=false;Statement Cache Size=0"
    //"DBConnection": "Data Source=localhost;Initial Catalog=DTSoftDB;Integrated Security=False;User ID=sa;Password=xxx;MultipleActiveResultSets=true;Encrypt=True;Max Pool Size=512;Min Pool Size=5;TrustServerCertificate=True"
  },
  //缓存类型（MemoryCache、RedisCache）
  "CacheModel": "MemoryCache",
  //Redis连接配置，CacheModel设置为MemoryCache时无需配置Redis
  "RedisHost": "localhost",
  "RedisPort": "6379",
  "RedisPassword": "xxx"
}

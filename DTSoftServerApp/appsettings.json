{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "urls": "http://*:8000",
  "Application": {
    "Initialization": {
      // 启动时自动检查并初始化系统数据库
      "RunOnStartup": true
    }
  },
  "ApiDocumentation": {
    // 是否启用 /apidoc；Development 环境默认也会启用
    "Enabled": true
  },
  "Authentication": {
    "Jwt": {
      // 至少16个字符的签名密钥
      "SigningKey": "DTSoftServerApp_Jwt_SecretKey_2026_32chars!@#$%^&*()",
      "Issuer": "DTSoftServer",
      "Audience": "DTSoftServerClient"
    }
  },
  "Security": {
    "PasswordHashing": {
      // PBKDF2 迭代次数。数值越高越安全但登录越慢；调整后用户成功登录会自动迁移到新值。
      "Iterations": 120000
    }
  },
  "Storage": {
    // 文件存储根目录
    "RootPath": "Attachment",
    "Attachments": {
      // 普通附件目录
      "Directory": "File"
    },
    "Users": {
      // 用户数据目录
      "Directory": "User",
      // 用户头像目录，最终路径为 Storage:RootPath/Storage:Users:Directory/Storage:Users:AvatarDirectory
      "AvatarDirectory": "Avatar"
    }
  },
  "Database": {
    // 数据库类型：MySql、SqlServer、Oracle、PostgreSql
    "Provider": "SqlServer"
  },
  "ConnectionStrings": {
    // "Default": "server=localhost;port=3306;database=DTSoftDB;uid=root;pwd=xxx;charset=utf8mb4;"
    "Default": "Data Source=localhost;Initial Catalog=DTSoftDB;Integrated Security=False;User ID=sa;Password=xxx;MultipleActiveResultSets=true;Encrypt=True;Max Pool Size=512;Min Pool Size=5;TrustServerCertificate=True"
    // "Default": "Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=localhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=XE)));User Id=C##DTSOFT;Password=123456;Metadata Pooling=false;Self Tuning=false;Statement Cache Size=0"
    //"Default": "Host=localhost;Port=5432;Database=DTSoftDB;Username=postgres;Password=xxx;Pooling=true;Maximum Pool Size=512;Minimum Pool Size=5;SSL Mode=Disable"
  },
  "Cache": {
    // 缓存类型：Memory、Redis
    "Provider": "Memory",
    "Redis": {
      // Cache:Provider 设置为 Memory 时无需配置 Redis
      "Host": "localhost",
      "Port": 6379,
      "Password": "xxx"
    }
  }
}
